{
  "name": "metricui",
  "version": "0.1.0",
  "description": "A React component library for building data dashboards — KPI cards, charts, tables, and more with built-in formatting, theming, and data states.",
  "keywords": [
    "react",
    "dashboard",
    "charts",
    "kpi",
    "metrics",
    "data-visualization",
    "components",
    "nivo",
    "tailwindcss"
  ],
  "author": "Matt McGowen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpmcgowen/metricui"
  },
  "homepage": "https://metricui.dev",
  "bugs": {
    "url": "https://github.com/mpmcgowen/metricui/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:lib": "tsup && postcss src/app/globals.css -o dist/styles.css --no-map",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "next start",
    "lint": "eslint",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@nivo/bar": "^0.99.0",
    "@nivo/bullet": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/funnel": "^0.99.0",
    "@nivo/heatmap": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/pie": "^0.99.0"
  },
  "peerDependenciesMeta": {
    "@nivo/bar": { "optional": true },
    "@nivo/bullet": { "optional": true },
    "@nivo/core": { "optional": true },
    "@nivo/funnel": { "optional": true },
    "@nivo/heatmap": { "optional": true },
    "@nivo/line": { "optional": true },
    "@nivo/pie": { "optional": true }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@nivo/bar": "^0.99.0",
    "@nivo/bullet": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/funnel": "^0.99.0",
    "@nivo/heatmap": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/pie": "^0.99.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "jsdom": "^29.0.1",
    "next": "16.2.0",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shiki": "^4.0.2",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
