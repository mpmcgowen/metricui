{
  "name": "@metricui/mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the MetricUI dashboard component library — exposes full API surface to AI coding tools",
  "type": "module",
  "bin": {
    "metricui-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "metricui",
    "dashboard",
    "react",
    "ai"
  ],
  "mcpName": "io.github.mpmcgowen/metricui",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpmcgowen/metricui.git",
    "directory": "mcp-server"
  },
  "homepage": "https://metricui.com"
}
